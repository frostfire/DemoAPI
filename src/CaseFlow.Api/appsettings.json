{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "AnonymousPermitPerMinute": 30,
    "AuthenticatedPermitPerMinute": 300,
    "AdminPermitPerMinute": 1000
  },
  "Jwt": {
    "Issuer": "caseflow-api",
    "Audience": "caseflow-api",
    "SigningKey": ""
  },
  "DemoAuth": {
    "Enabled": false
  }
}
