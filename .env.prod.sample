# Production/demo environment template. On the server this becomes
# /opt/demoapi/env/production.env (chmod 600), symlinked as .env beside the
# compose file. Real secret values are generated on the box at deploy time and
# never committed.

# Database (the containerized Postgres reads these; the app builds its
# connection string from them in docker-compose.prod.yml).
POSTGRES_DB=caseflow
POSTGRES_USER=caseflow
POSTGRES_PASSWORD=__generate_on_server__

# API host loopback port (host nginx proxies to this).
API_PORT=8093

# JWT signing key - min 32 bytes; generate with: openssl rand -base64 48
Jwt__SigningKey=__generate_on_server__

# Demo sandbox: public Swagger UI, seeding, read-only dashboard, periodic reset.
Demo__Enabled=true
DemoAuth__Enabled=true
Demo__MaxCasesPerOrganization=50
Demo__ResetEvery=03:00:00

# Apply EF Core migrations on startup (the demo's throwaway database).
Database__MigrateOnStartup=true

# Approved cases auto-archive after this delay; short here so the scheduled
# Hangfire job is visibly pending in the dashboard.
Workflow__AutoArchiveAfter=2.00:00:00
